# Copy to .env.local for local dev, or set as Project Environment Variables in Vercel.

# Pooled Neon connection string. Use the "Pooled" URL ending in -pooler.
DATABASE_URL=postgres://USER:PASS@HOST/DB?sslmode=require

# Long random secret used to sign Auth.js session JWTs (HS256).
# Generate with:  openssl rand -base64 48
AUTH_SECRET=replace-with-a-long-random-string

# Where the app runs (no trailing slash).
NEXTAUTH_URL=http://localhost:3004

# Resend.com API key for sending verification + reset emails (free tier).
# Leave blank to log emails to stdout instead.
RESEND_API_KEY=
EMAIL_FROM=portal@wavionex.com
